// IEEE Standard 830-1998 compliant database specification for AURXON ERP Lite
// Dedicated to Indian Educational Institution Workflows (CBSE/ICSE/State Boards)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  INSTITUTE_ADMIN
  STAFF
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
}

model Institution {
  id           String   @id @default(uuid())
  name         String
  logoUrl      String?
  primaryColor String   @default("#0284c7") // Glacier sky blue default
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users     User[]
  students  Student[]
  staff     Staff[]
  classes   Class[]
  fees      FeeStructure[]
  notices   Notice[]
  expenses  Expense[]
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  passwordHash  String
  role          String      // e.g. "SUPER_ADMIN", "INSTITUTE_ADMIN", etc.
  isActive      Boolean     @default(true)
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Profile Relations
  studentProfile Student?
  parentProfile  Parent?
  staffProfile   Staff?
  auditLogs      AuditLog[]
}

model Student {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  
  // Permanent unique identification mapping (Indian Scholar Number System)
  scholarNumber String      @unique
  rollNumber    String      // Class-specific dynamic number (changes annually)
  
  firstName     String
  lastName      String
  dateOfBirth   DateTime
  gender        String
  admissionDate DateTime    @default(now())
  status        String      @default("ACTIVE") // ACTIVE, GRADUATED, DROPPED
  
  // Indian Demographics & Identity Verification
  aadhaarNumber          String?    // 12-digit UIDAI Verification ID
  samagraId              String?    // State SSSMID Family / Individual ID
  familyId               String?    // Family Ration Card / Household ID
  penNumber              String?    // Permanent Education Number
  birthCertificateNumber String?
  
  bloodGroup             String?
  religion               String?
  casteCategory          String?    // GENERAL, OBC, SC, ST
  nationality            String     @default("Indian")
  motherTongue           String?
  
  // Parent & Guardian Details
  fatherName             String?
  motherName             String?
  fatherOccupation       String?
  motherOccupation       String?
  annualIncome           Float?
  
  // Indian Structured Address Mapping
  houseNo                String?
  street                 String?
  city                   String?    // Village / Town
  district               String?
  state                  String?
  pinCode                String?
  
  // Banking Credentials
  bankName               String?
  accHolderName          String?
  accNumber              String?
  ifscCode               String?
  bankBranch             String?
  upiId                  String?

  // Transfer Certificate (TC) & Migration
  prevSchoolName         String?
  tcNumber               String?
  migrationCertNo        String?

  parentId      String?
  parent        Parent?     @relation(fields: [parentId], references: [id])
  classId       String
  class         Class       @relation(fields: [classId], references: [id])
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  
  attendance    Attendance[]
  feeAllocations StudentFeeAllocation[]
  examResults   ExamResult[]
  documents     Document[]
  timeline      TimelineEvent[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([scholarNumber])
}

model Parent {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  firstName     String
  lastName      String
  phone         String
  occupation    String?
  address       String?
  students      Student[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Staff {
  id            String      @id @default(uuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  employeeId    String
  firstName     String
  lastName      String
  phone         String
  designation   String      // TEACHER, ACCOUNTANT, STAFF
  joiningDate   DateTime
  salary        Float
  status        String      @default("ACTIVE")
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  leaves        LeaveRequest[]
  classes       Class[]     @relation("ClassTeacher") // If teacher is class head
  subjects      Subject[]   // Subjects they teach
  lessonPlans   LessonPlan[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Class {
  id            String      @id @default(uuid())
  name          String      // e.g., "Grade 10", "Nursery"
  section       String?     // e.g., "A", "B"
  stream        String      @default("General") // General, Science, Commerce, Arts
  board         String      @default("CBSE")    // CBSE, ICSE, STATE_BOARD, NIOS
  classTeacherId String?
  classTeacher  Staff?      @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  
  students      Student[]
  subjects      Subject[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Subject {
  id            String      @id @default(uuid())
  name          String
  code          String
  classId       String
  class         Class       @relation(fields: [classId], references: [id])
  teacherId     String?
  teacher       Staff?      @relation(fields: [teacherId], references: [id])
  exams         Exam[]
  lessonPlans   LessonPlan[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Attendance {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  date        DateTime
  status      String   // PRESENT, ABSENT, LATE, EXCUSED
  remarks     String?
  recordedById String  // Staff ID

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([studentId, date])
}

model FeeStructure {
  id            String      @id @default(uuid())
  name          String      // e.g., "Quarterly Tuition Term 1"
  amount        Float
  dueDate       DateTime
  description   String?
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  allocations   StudentFeeAllocation[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model StudentFeeAllocation {
  id             String       @id @default(uuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  amountDue      Float
  amountPaid     Float        @default(0)
  status         String       @default("UNPAID") // UNPAID, PARTIAL, PAID
  
  payments       Payment[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Payment {
  id             String               @id @default(uuid())
  allocationId   String
  allocation     StudentFeeAllocation @relation(fields: [allocationId], references: [id])
  amount         Float
  paymentDate    DateTime             @default(now())
  paymentMethod  String               // CASH, CARD, ONLINE, UPI
  receiptNumber  String               @unique
  remarks        String?

  createdAt      DateTime             @default(now())
}

model Exam {
  id            String       @id @default(uuid())
  name          String       // e.g., "Term 1 Final", "Monthly Unit Test 2"
  examType      String       @default("UNIT_TEST") // UNIT_TEST, HALF_YEARLY, ANNUAL, BOARD
  subjectId     String
  subject       Subject      @relation(fields: [subjectId], references: [id])
  maxMarks      Float
  practicalMarks Float       @default(0)
  internalMarks Float        @default(0)
  examDate      DateTime

  results       ExamResult[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model ExamResult {
  id          String   @id @default(uuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id])
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  marksObtained Float
  remarks     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([examId, studentId])
}

model Notice {
  id            String      @id @default(uuid())
  title         String
  content       String
  targetRoles   String      // Comma-separated roles list
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  authorName    String

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  name      String
  fileUrl   String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())
}

model TimelineEvent {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  type        String   // ADMISSION, PROMOTION, ACADEMIC_AWARD, MIGRATION
  description String
  eventDate   DateTime @default(now())
}

model LeaveRequest {
  id          String   @id @default(uuid())
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id])
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}

model LessonPlan {
  id              String   @id @default(uuid())
  title           String
  content         String
  status          String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, REVISED
  syllabusPercent Int      @default(0)
  subjectId       String
  subject         Subject  @relation(fields: [subjectId], references: [id])
  teacherId       String
  teacher         Staff    @relation(fields: [teacherId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Expense {
  id            String      @id @default(uuid())
  title         String
  amount        Float
  category      String      // UTILITY, SALARY, RENT, MAINTENANCE, OTHER
  expenseDate   DateTime    @default(now())
  paymentMethod String      // CASH, CARD, BANK_TRANSFER, UPI
  receiptUrl    String?
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
