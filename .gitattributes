# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly ensure Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Ensure standard image and fonts are treated as binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
